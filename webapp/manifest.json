{
  "_version": "1.85.0",
  "sap.app": {
    "id": "gvtracker",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.25.0",
      "toolsId": "453dd7e6-a322-4b6c-9a0f-8044ea09652b"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v2/gv-tracker/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "2.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.148.1",
      "libs": {
        "sap.m": {},
        "sap.ui.comp":{},
        "sap.ui.table":{},
        "sap.ui.core": {},
        "sap.ui.layout": {},
         "sap.ui.unified": {}

      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "gvtracker.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true,
          "defaultBindingMode": "TwoWay",
          "defaultCountMode": "Inline",
          "useBatch": false
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "gvtracker.view",
        "async": true,
        "viewPath": "gvtracker.view"
      },
      "routes": [
        {
          "name": "RouteHome",
          "pattern": ":?query:",
          "target": [
            "TargetHome"
          ]
        },
        {
          "name": "RouteCreate",
          "pattern": "create",
          "target": [
            "TargetCreate"
          ]
        },
        {
          "name": "RouteBillInfo",
          "pattern": "billinfo/{mobile}/{giftValue}",
          "target": [
            "TargetBillInfo"
          ]
        },
        {
          "name": "RouteReturnDisplay",
          "pattern": "returndisplay/{gvrNo}",
          "target": ["TargetReturnDisplay"]
        },
        {
          "name": "RouteReplacementDisplay",
          "pattern": "replacementdisplay/{gvrNo}",
          "target": ["TargetReplacementDisplay"]
        },
        {
          "name": "RouteDisplay",
          "pattern": "display/{gvrNo}",
          "target": [
            "TargetDisplay"
          ]
        },
        {
          "name": "RouteCustomerBillDisplay",
          "pattern": "billdisplay/{gvrNo}",
          "target": [
            "TargetCustomerBillDisplay"
          ] 
        }
      ],
      "targets": {
        "TargetHome": {
          "id": "Home",
          "name": "Home"
        },
        "TargetCreate": {
          "id": "Create",
          "name": "Create"
        },
        "TargetBillInfo": {
          "id": "BillInfo",
          "name": "BillInfo"
        },
        "TargetDisplay": {
          "id": "Display",
          "name": "Display"
        },
        "TargetReturnDisplay": {
          "id": "ReturnDisplay",
          "name": "ReturnDisplay"
        },
        "TargetReplacementDisplay": {
          "id": "ReplacementDisplay",
          "name": "ReplacementDisplay"
        },
        "TargetCustomerBillDisplay": {
          "id": "CustomerBillDisplay",
          "name": "CustomerBillDisplay"
        }
      }
    },
    "rootView": {
      "viewName": "gvtracker.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}
