<mvc:View
    controllerName="gvtracker.controller.Display"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <SplitContainer id="splitContainer">

        <!-- MASTER PAGE -->
        <masterPages>

            <Page
                title="GVR List"
                showHeader="true">

                <content>

                    <SegmentedButton
                        width="100%"
                        selectedKey="Create"
                        selectionChange="onModeChange">

                        <items>
                            <SegmentedButtonItem
                                key="Create"
                                text="Create"/>

                            <SegmentedButtonItem
                                key="Return"
                                text="Return"/>

                            <SegmentedButtonItem
                                key="Replacement"
                                text="Replacement"/>
                        </items>

                    </SegmentedButton>

                    <SearchField
                        width="100%"
                        placeholder="Search by GVR Number"
                        liveChange="onSearchGVR"/>

                    <List
                        id="gvrList"
                        mode="SingleSelectMaster"
                        includeItemInSelection="true"
                        items="{gvr>/results}"
                        selectionChange="onGVRSelect">

                        <StandardListItem
                            title="{gvr>gv_no}" />

                    </List>

                </content>

            </Page>

        </masterPages>

        <!-- DETAIL PAGE -->
        <detailPages>

            <Page showHeader="false">

                <content>

                    <!-- Header -->
                    <Toolbar>

                        <Button
                            icon="sap-icon://nav-back"
                            type="Transparent"
                            press="onBack"/>

                        <Title
                            text="Gift Voucher Tracker - Gift Issue to Customer Activity - DISPLAY Screen"/>

                        <ToolbarSpacer/>

                        <Button
                            text="Home"
                            type="Transparent"
                            press="onBack"/>

                    </Toolbar>

                    <!-- Details Area -->
                    <VBox class="sapUiMediumMargin">

                        <!-- Row 1 -->
                        <HBox justifyContent="SpaceAround"
                                width="100%">

                            <VBox width="30%">

                                <Label text="GVR Number :"/>

                               <Text text="{selectedGVR>/gv_no}"/>

                            </VBox>

                            <VBox width="30%">

                                <Label text="Customer Type :"/>

                                <Text text="{selectedGVR>/cust_type/name}"/>

                            </VBox>

                            <VBox width="30%">

                                <Label text="GVR Date :"/>

                                <Text text="{selectedGVR>/formattedDate}"/>
                            </VBox>

                        </HBox>

                        <!-- Row 2 -->
                        <HBox
                            justifyContent="SpaceBetween"
                            class="sapUiTinyMarginTop">

                            <VBox width="30%">

                                <Label text="Total Gift Items Value :"/>

                               <Text text="{selectedGVR>/assignGiftsTotal_amt}"/>

                            </VBox>

                            <VBox width="30%">

                                <Label text="Customer Mobile :"/>

                                <Text text="{selectedGVR>/customer/phone}"/>

                            </VBox>

                            <VBox width="30%">

                                <Label text="Employee ID/Name :"/>

                                <Text text="102312"/>

                            </VBox>

                        </HBox>

                        <!-- Row 3 -->
                        <HBox
                            justifyContent="SpaceBetween"
                            class="sapUiTinyMarginTop">

                            <VBox width="30%">

                                <Button
                                    text="View Customer Bill Info"
                                    width="220px"
                                    press="onViewCustomerBillInfo"/>

                            </VBox>

                            <VBox width="30%">

                                <Label text="Shopping Mall :"/>

                               <Text text="{selectedGVR>/shoppingMall/plant_code}"/>

                            </VBox>

                            <VBox width="30%">

                                <Label text="Campaign :"/>

                                <Text text="{selectedGVR>/campaign_name}"/>

                            </VBox>

                        </HBox>

                        <!-- Comments -->
                        <HBox class="sapUiSmallMarginTop">

                            <VBox width="100%">

                                <Label text="Comments :"/>

                                <Text text="{selectedGVR>/comment}"/>
                            </VBox>

                        </HBox>

                    </VBox>

                    <!-- Table Title -->
                    <Title
                        text="Gift Items list issued to Customer"
                        level="H4"
                        class="sapUiTinyMarginTop sapUiSmallMarginBegin"/>

                    

                    <!-- Gift Table -->
                    <Table
                        id="giftTable"
                        items="{gift>/items}"
                        width="100%"
                        inset="false"
                        sticky="ColumnHeaders"
                        fixedLayout="false">

                        <columns>

                            <Column width="10rem">
                                <Text text="Material Name"/>
                            </Column>

                            <Column width="10rem">
                                <Text text="Description"/>
                            </Column>

                            <Column width="6rem">
                                <Text text="Price"/>
                            </Column>

                            <Column width="6rem">
                                <Text text="Issue Qty"/>
                            </Column>

                            <Column width="10rem">
                                <Text text="Coupon"/>
                            </Column>

                            <Column width="8rem">
                                <Text text="Brand"/>
                            </Column>

                            <Column width="8rem">
                                <Text text="Expiry Date"/>
                            </Column>
                        </columns>

                        <items>

                        <ColumnListItem>

                            <cells>

                                <Text text="{gift>giftVoucher/material}"/>
                                <Text text="{gift>giftVoucher/descr}"/>
                                <Text text="{gift>giftVoucher/price}"/>
                                <Text text="{gift>issue_quantity}"/>
                                <Text text="{gift>giftVoucher/coupon}"/>
                                <Text text="{gift>giftVoucher/brand}"/>
                                <Text
                                    text="{
                                        path:'gift>giftVoucher/expDate',
                                        type:'sap.ui.model.type.Date',
                                        formatOptions:{
                                            pattern:'dd/MM/yyyy'
                                        }
                                    }"/>                            </cells>

                        </ColumnListItem>

                    </items>

                    </Table>

                </content>

                <footer>

                    <Toolbar>

                        <ToolbarSpacer/>

                        <Button
                            text="Back"
                            type="Transparent"
                            press="onBack"/>

                    </Toolbar>

                </footer>

            </Page>

        </detailPages>

    </SplitContainer>

</mvc:View>