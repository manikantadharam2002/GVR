<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="cameraDialog"
        title="Capture Image"
        contentWidth="900px"
        contentHeight="600px">

        <content>

            <VBox width="100%">

                <core:HTML
                    id="cameraHtml"
                    content="&lt;video id='cameraVideo' autoplay playsinline style='width:100%;height:450px;border:1px solid #ccc'&gt;&lt;/video&gt;" />

            </VBox>

        </content>

        <beginButton>

            <Button
                text="Capture Photo"
                press="onCapturePhoto"/>

        </beginButton>

        <endButton>

            <Button
                text="Close"
                press="onCloseCamera"/>

        </endButton>

    </Dialog>

</core:FragmentDefinition>