<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        title="Image Preview"
        contentWidth="700px"
        contentHeight="500px">

        <content>

            <Image
                id="previewImage"
                width="100%"
                height="100%"
                decorative="false"/>

        </content>

        <endButton>

            <Button
                text="Close"
                press="onClosePreview"/>

        </endButton>

    </Dialog>

</core:FragmentDefinition>